[Unit]
Description=GOAT AI FastAPI server
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/GOAT_AI
ExecStart=%h/GOAT_AI/.venv/bin/python -m uvicorn server:app \
    --host 0.0.0.0 --port 62606 --workers 2
Restart=always
RestartSec=5
StandardOutput=append:%h/GOAT_AI/fastapi.log
StandardError=append:%h/GOAT_AI/fastapi.log
EnvironmentFile=-%h/GOAT_AI/.env

[Install]
WantedBy=default.target
