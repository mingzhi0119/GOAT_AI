{
  "name": "goat-ai-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "lint": "eslint .",
    "bundle:check": "node ./scripts/check-bundle-budget.mjs",
    "contract:generate": "node ./scripts/generate-api-types.mjs",
    "contract:check": "node ./scripts/generate-api-types.mjs --check",
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "desktop:sidecar:build": "node ./scripts/run-python.mjs ../tools/desktop/build_desktop_sidecar.py",
    "desktop:dev": "node ./scripts/run-tauri.mjs dev --config src-tauri/tauri.conf.json",
    "desktop:build": "node ./scripts/run-tauri.mjs build --config src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.54.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.38.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24.14.1 <25"
  }
}
