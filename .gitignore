# Python
__pycache__/
*.py[cod]

# Logs
logs/
*.log

# Local SQLite backups (tools/ops/backup_chat_db.py)
backups/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# Cursor IDE — ignore user settings/cache, keep project rules
.cursor/*
!.cursor/rules/
!.cursor/rules/*.mdc
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment
.env
.env.production
.env.local
.env.development.local
.env.test.local
.env.production.local
.venv/
.venv314/

# Local runtime artifacts
# Default GOAT_DATA_DIR — uploads, vector index, media (do not commit)
var/
data/
chat_logs.db
chat_logs.db-*
*.pid
.desktop-sidecar-smoke/
.pytest_tmp/

# Build
frontend/dist
frontend/node_modules
frontend/src-tauri/binaries/*
!frontend/src-tauri/binaries/.gitkeep
frontend/src-tauri/target/
frontend/src-tauri/.desktop-sidecar-build/
frontend/src-tauri/gen/
# TypeScript incremental cache (regenerated by tsc; must not block git checkout / deploy)
frontend/**/*.tsbuildinfo

# Local git helper (stage + commit + push); not committed to repo
git-commit-push.ps1
git-commit-push.bat

# Selenium automation profile (may contain session cookies)
scripts/.selenium_chrome_profile/
scripts/.selenium_chrome_profile_workers/
scripts/open_close_url_loop.py
