# Copy to .env on the server (do not commit .env). Or export these before deploy.

# Ollama HTTP API.
# Leave this unset to use the app's default auto-detection:
# - Windows local deploys prefer Ollama on 127.0.0.1:11434
# - sibling local runtime layouts prefer 127.0.0.1:11435
# Set this only when you intentionally want another Ollama instance.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Seconds for each streaming request to Ollama
OLLAMA_GENERATE_TIMEOUT=120

# Seconds to wait for the first streamed chat SSE event before treating /api/chat as stalled
OLLAMA_CHAT_FIRST_EVENT_TIMEOUT=90

# Upload limits (must stay consistent with backend validation)
GOAT_MAX_UPLOAD_MB=20
GOAT_MAX_DATAFRAME_ROWS=50000

# Vision image uploads (POST /api/media/uploads); raw bytes cap before chat attach
# GOAT_MAX_IMAGE_MEDIA_BYTES=12582912
# GOAT_MAX_IMAGE_EDGE_PX=2048

# RAG-3 retrieval quality: default profile uses this rerank mode (rag3_lexical / rag3_quality always use lexical rerank)
# GOAT_RAG_RERANK_MODE=passthrough
# GOAT_RAG_RERANK_MODE=lexical

# Use Ollama /api/chat for multi-turn (recommended). Set false to use /api/generate with transcript.
GOAT_USE_CHAT_API=true

# Optional: override default system prompt (UR/Simon policy-safe default is in goat_ai.config)
# GOAT_SYSTEM_PROMPT=Your full prompt text here...

# Optional: load system prompt from a file (UTF-8). Overrides GOAT_SYSTEM_PROMPT if set.
# GOAT_SYSTEM_PROMPT_FILE=/path/to/prompt.txt

# Path to the SQLite database that stores chat Q&A logs.
# Default: <project_root>/chat_logs.db  (created automatically on first run)
# GOAT_LOG_PATH=/home/ubuntu/GOAT_AI/chat_logs.db

# JSON logs (one object per line) with request_id and structured extras: set GOAT_LOG_JSON=1
# GOAT_LOG_JSON=1

# Readiness: skip Ollama HTTP probe (SQLite-only ready) for dev/CI without Ollama
# GOAT_READY_SKIP_OLLAMA_PROBE=1

# Ollama read-resilience policy (Phase 13 Wave B, idempotent reads only: /api/tags and /api/show)
# GOAT_OLLAMA_READ_RETRY_ATTEMPTS=3
# GOAT_OLLAMA_READ_RETRY_BASE_MS=120
# GOAT_OLLAMA_READ_RETRY_JITTER_MS=80
# GOAT_OLLAMA_CIRCUIT_BREAKER_FAILURES=3
# GOAT_OLLAMA_CIRCUIT_BREAKER_OPEN_SEC=20

# Idempotency cache TTL in seconds (SQLite-backed, used by /api/upload/analyze and chat session append)
# GOAT_IDEMPOTENCY_TTL_SEC=300

# Chat capacity guardrails (Phase 13.3): reject oversized requests with 422.
# GOAT_MAX_CHAT_MESSAGES=120
# GOAT_MAX_CHAT_PAYLOAD_BYTES=512000

# Optional API protection for all routes except /api/health and /api/ready.
# When GOAT_API_KEY is set, clients must send it in X-GOAT-API-Key.
# GOAT_API_KEY=replace-with-a-long-random-secret
# GOAT_RATE_LIMIT_WINDOW_SEC=60
# GOAT_RATE_LIMIT_MAX_REQUESTS=60

# Deployment target resolution.
# auto  : prefer 62606, but fall back to 8002 when the current environment cannot bind/use the server port
# server: require the server port
# local : always use the local fallback port
# GOAT_DEPLOY_TARGET=auto
# GOAT_SERVER_PORT=62606
# GOAT_LOCAL_PORT=8002

# Rolling window size for /api/system/inference (average chat stream duration, ms samples)
# GOAT_LATENCY_ROLLING_MAX_SAMPLES=20

# GPU telemetry for /api/system/gpu (nvidia-smi). On multi-GPU hosts, set UUID so the UI does not bind to the wrong card.
# Example A100 on school host: GPU 0 = A100, GPU 1 = GT 1030 — use the A100 UUID.
# GOAT_GPU_UUID=GPU-fb2cf8f7-e9bf-f136-a3bb-e150426598e8
# GOAT_GPU_INDEX=0

# Ops scripts (see docs/OPERATIONS.md — User-space ops): optional overrides for rotate/backup/healthcheck
# GOAT_AI_ROOT=/home/you/GOAT_AI
# GOAT_LOG_MAX_MB=50
# GOAT_BACKUP_DIR=/home/you/GOAT_AI/backups
# GOAT_HEALTH_URL=http://127.0.0.1:62606/api/health

# Local sibling Ollama management:
#   bash scripts/start_ollama_local.sh
#   bash scripts/status_ollama_local.sh
#   bash scripts/stop_ollama_local.sh
#   bash scripts/ollama_local.sh pull <model>

# Code execution sandbox (future; §15 capability gate). Off by default. Requires Docker socket/pipe probe to pass.
# GOAT_FEATURE_CODE_SANDBOX=0
# GOAT_FEATURE_CODE_SANDBOX=1
# Optional explicit Docker socket (empty = default: Unix /var/run/docker.sock or Windows \\.\pipe\docker_engine)
# GOAT_DOCKER_SOCKET=/var/run/docker.sock
