# Copy to .env on the server (do not commit .env). Or export these before deploy.

# --- Developer CLI (repository root) ---
# Prefer running tools as modules so imports resolve without manual PYTHONPATH:
#   python -m tools.quality.run_rag_eval
#   python -m tools.contracts.check_api_contract_sync
#   python -m tools.contracts.generate_llm_api_yaml
# Optional: if you must run a file path (not recommended), set for the current shell only:
#   PYTHONPATH=.
# Note: .env is loaded by the app/runtime, not by your shell; do not assume PYTHONPATH here
# affects terminal commands unless you use direnv or explicit export.

# Ollama HTTP API.
# Leave this unset to use the standard local Ollama address on 127.0.0.1:11434.
# Set this only when you intentionally want another Ollama instance.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Seconds for each streaming request to Ollama
OLLAMA_GENERATE_TIMEOUT=120

# Seconds to wait for the first streamed chat SSE event before treating /api/chat as stalled
OLLAMA_CHAT_FIRST_EVENT_TIMEOUT=90

# Upload limits (must stay consistent with backend validation)
GOAT_MAX_UPLOAD_MB=20
GOAT_MAX_DATAFRAME_ROWS=50000

# Vision image uploads (POST /api/media/uploads); raw bytes cap before chat attach
# GOAT_MAX_IMAGE_MEDIA_BYTES=12582912
# GOAT_MAX_IMAGE_EDGE_PX=2048

# RAG-3 retrieval quality: default profile uses this rerank mode (rag3_lexical / rag3_quality always use lexical rerank)
# GOAT_RAG_RERANK_MODE=passthrough
# GOAT_RAG_RERANK_MODE=lexical

# Use Ollama /api/chat for multi-turn (recommended). Set false to use /api/generate with transcript.
GOAT_USE_CHAT_API=true

# Optional: override default system prompt (UR/Simon policy-safe default is in goat_ai.config)
# GOAT_SYSTEM_PROMPT=Your full prompt text here...

# Optional: load system prompt from a file (UTF-8). Overrides GOAT_SYSTEM_PROMPT if set.
# GOAT_SYSTEM_PROMPT_FILE=/path/to/prompt.txt

# Runtime root for server/check-out deploys.
# Default: <project_root>/var
# GOAT_RUNTIME_ROOT=/home/ubuntu/GOAT_AI/var
#
# Path to the SQLite database that stores chat Q&A logs.
# Default: <project_root>/var/chat_logs.db  (created automatically on first run)
# GOAT_LOG_PATH=/home/ubuntu/GOAT_AI/var/chat_logs.db
#
# Directory for deploy/runtime logs.
# Default: <project_root>/var/logs
# GOAT_LOG_DIR=/home/ubuntu/GOAT_AI/var/logs

# JSON logs (one object per line) with request_id and structured extras: set GOAT_LOG_JSON=1
# GOAT_LOG_JSON=1

# Readiness: skip Ollama HTTP probe (SQLite-only ready) for dev/CI without Ollama
# GOAT_READY_SKIP_OLLAMA_PROBE=1

# Ollama read-resilience policy (Phase 13 Wave B, idempotent reads only: /api/tags and /api/show)
# GOAT_OLLAMA_READ_RETRY_ATTEMPTS=3
# GOAT_OLLAMA_READ_RETRY_BASE_MS=120
# GOAT_OLLAMA_READ_RETRY_JITTER_MS=80
# GOAT_OLLAMA_CIRCUIT_BREAKER_FAILURES=3
# GOAT_OLLAMA_CIRCUIT_BREAKER_OPEN_SEC=20
# Max concurrent Ollama inference requests per app process. Extra requests wait
# in FIFO order. Set this to 1 on constrained hosts if two active models are too heavy.
# GOAT_OLLAMA_MAX_CONCURRENT_REQUESTS=2

# Idempotency cache TTL in seconds (SQLite-backed, used by /api/upload/analyze and chat session append)
# GOAT_IDEMPOTENCY_TTL_SEC=300

# Chat capacity guardrails (Phase 13.3): reject oversized requests with 422.
# GOAT_MAX_CHAT_MESSAGES=120
# GOAT_MAX_CHAT_PAYLOAD_BYTES=512000

# Auth is removed for demo deployments. Leave all historical Auth env vars unset:
# GOAT_API_KEY, GOAT_API_KEY_WRITE, GOAT_API_CREDENTIALS_JSON,
# GOAT_SHARED_ACCESS_*, GOAT_ACCOUNT_*, GOOGLE_*, GOAT_REQUIRE_SESSION_OWNER.
# load_settings() fails fast if any of them are configured.
# Request-rate limiting. Defaults:
#   local/school: 60 requests per minute per caller/IP
#   remote: 20 requests per minute per caller/IP
# GOAT_RATE_LIMIT_WINDOW_SEC=60
# GOAT_RATE_LIMIT_MAX_REQUESTS=20

# OpenTelemetry (optional; default off — no heavy imports when disabled)
# GOAT_OTEL_ENABLED=0
# GOAT_OTEL_EXPORTER=console
# GOAT_OTEL_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Deployment shape.
# 0 = local (Windows PowerShell deploy, local Linux deploy, packaged desktop app)
# 1 = school_server (school Ubuntu profile + local Ollama helper)
# 2 = remote (Vercel frontend + DuckDNS/Nginx backend)
# GOAT_DEPLOY_MODE=0
# GOAT_SERVER_PORT=62606
# GOAT_LOCAL_PORT=62606
# GOAT_DESKTOP_BACKEND_PORT=62606

# Rolling window size for /api/system/inference (average chat stream duration, ms samples)
# GOAT_LATENCY_ROLLING_MAX_SAMPLES=20

# GPU telemetry for /api/system/gpu (nvidia-smi). On multi-GPU hosts, set UUID so the UI does not bind to the wrong card.
# Example A100 on school host: GPU 0 = A100, GPU 1 = GT 1030 — use the A100 UUID.
# GOAT_GPU_UUID=GPU-fb2cf8f7-e9bf-f136-a3bb-e150426598e8
# GOAT_GPU_INDEX=0

# Ops scripts (see docs/operations/OPERATIONS.md — User-space ops): optional overrides for rotate/backup/healthcheck
# GOAT_AI_ROOT=/home/you/GOAT_AI
# GOAT_LOG_MAX_MB=50
# GOAT_BACKUP_DIR=/home/you/GOAT_AI/backups
# GOAT_HEALTH_URL=http://127.0.0.1:62606/api/health

# Simon school Ubuntu server profile (explicit opt-in only; not part of the generic default path):
# GOAT_USE_SCHOOL_OLLAMA_LOCAL=1
# Optional profile alias instead of the boolean switch:
# GOAT_OLLAMA_PROFILE=school-ubuntu
# OLLAMA_BASE_URL=http://127.0.0.1:11435
# Keep school-specific overrides in a dedicated env file when using
# ops/systemd/goat-ai.school-ubuntu.service, for example $HOME/GOAT_AI/.env.school-ubuntu.
# School-only helper scripts:
#   bash scripts/ollama/start_ollama_local.sh
#   bash scripts/ollama/status_ollama_local.sh
#   bash scripts/ollama/stop_ollama_local.sh
#   bash scripts/ollama/ollama_local.sh pull <model>

# Code execution sandbox. Off by default. Provider defaults to Docker; localhost is a dev fallback.
# GOAT_FEATURE_CODE_SANDBOX=0
# GOAT_FEATURE_CODE_SANDBOX=1
# GOAT_CODE_SANDBOX_PROVIDER=docker
# GOAT_CODE_SANDBOX_PROVIDER=localhost
# GOAT_FEATURE_AGENT_WORKBENCH=0
# Workbench public-web retrieval (experimental DDGS / DuckDuckGo-style provider).
# GOAT_WORKBENCH_WEB_PROVIDER=duckduckgo
# GOAT_WORKBENCH_WEB_PROVIDER=disabled
# GOAT_WORKBENCH_WEB_MAX_RESULTS=6
# GOAT_WORKBENCH_WEB_TIMEOUT_SEC=15
# GOAT_WORKBENCH_WEB_REGION=wt-wt
# GOAT_WORKBENCH_WEB_SAFESEARCH=moderate
# Optional explicit Docker socket (empty = default: Unix /var/run/docker.sock or Windows \\.\pipe\docker_engine)
# GOAT_DOCKER_SOCKET=/var/run/docker.sock
# Optional shell override for localhost provider (empty = auto-detect pwsh/powershell on Windows, sh on Unix)
# GOAT_CODE_SANDBOX_LOCALHOST_SHELL=powershell.exe

# Safeguard (content moderation) configuration.
# GOAT_SAFEGUARD_ENABLED — master on/off switch. Default: true (enabled).
#   false → disable all moderation; equivalent to GOAT_SAFEGUARD_MODE=off.
# GOAT_SAFEGUARD_ENABLED=true
#
# GOAT_SAFEGUARD_MODE — scope of checks when enabled. Default: full.
#   off         → no moderation (same effect as GOAT_SAFEGUARD_ENABLED=false)
#   input_only  → moderate user input only; skip output check
#   output_only → moderate assistant output only; skip input check
#   full        → moderate both input and output (default, recommended)
# GOAT_SAFEGUARD_MODE=full
