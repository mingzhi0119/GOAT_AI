# Copy to .env on the server (do not commit .env). Or export these before deploy.

# Ollama HTTP API (bind Ollama to 127.0.0.1 on the host; do not expose without auth)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Seconds for each streaming request to Ollama
OLLAMA_GENERATE_TIMEOUT=120

# Upload limits (must stay consistent with backend validation)
GOAT_MAX_UPLOAD_MB=20
GOAT_MAX_DATAFRAME_ROWS=50000

# Use Ollama /api/chat for multi-turn (recommended). Set false to use /api/generate with transcript.
GOAT_USE_CHAT_API=true

# Optional: override default system prompt (UR/Simon policy-safe default is in goat_ai.config)
# GOAT_SYSTEM_PROMPT=Your full prompt text here...

# Optional: load system prompt from a file (UTF-8). Overrides GOAT_SYSTEM_PROMPT if set.
# GOAT_SYSTEM_PROMPT_FILE=/path/to/prompt.txt

# Path to the SQLite database that stores chat Q&A logs.
# Default: <project_root>/chat_logs.db  (created automatically on first run)
# GOAT_LOG_PATH=/home/ubuntu/GOAT_AI/chat_logs.db

# GPU telemetry for /api/system/gpu (nvidia-smi). On multi-GPU hosts, set UUID so the UI does not bind to the wrong card.
# Example A100 on school host: GPU 0 = A100, GPU 1 = GT 1030 — use the A100 UUID.
# GOAT_GPU_UUID=GPU-fb2cf8f7-e9bf-f136-a3bb-e150426598e8
# GOAT_GPU_INDEX=0

# Ops scripts (see docs/OPERATIONS.md — User-space ops): optional overrides for rotate/backup/healthcheck
# GOAT_AI_ROOT=/home/you/GOAT_AI
# GOAT_LOG_MAX_MB=50
# GOAT_BACKUP_DIR=/home/you/GOAT_AI/backups
# GOAT_HEALTH_URL=http://127.0.0.1:62606/api/health
