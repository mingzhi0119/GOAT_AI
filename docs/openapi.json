  "components": {
    "schemas": {
      "Body_analyze_upload_json_api_upload_analyze_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_analyze_upload_json_api_upload_analyze_post"
      },
      "Body_upload_and_parse_api_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_and_parse_api_upload_post"
      },
      "ChatMessage": {
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^(user|assistant|system)$",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "file_context": {
            "type": "boolean",
            "title": "File Context",
            "description": "True when this user message is upload-derived tabular file context.",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "ChatMessage",
        "description": "A single turn in the conversation (mirrors goat_ai.types.ChatTurn)."
      },
      "ChatRequest": {
        "properties": {
          "model": {
            "type": "string",
            "minLength": 1,
            "title": "Model",
            "default": "gemma4:26b"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "type": "array",
            "minItems": 1,
            "title": "Messages"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "system_instruction": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 8000
              },
              {
                "type": "null"
              }
            ],
            "title": "System Instruction",
            "description": "Optional user instructions merged after the base system prompt."
          },
          "temperature": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 2.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature",
            "description": "Ollama sampling temperature (optional)."
          },
          "max_tokens": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 131072.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Tokens",
            "description": "Max tokens to generate (Ollama num_predict)."
          },
          "top_p": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Top P",
            "description": "Ollama top_p nucleus sampling."
          }
        },
        "type": "object",
        "required": [
          "messages"
        ],
        "title": "ChatRequest",
        "description": "Body for POST /api/chat."
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "additionalProperties": true,
                "type": "object"
              }
            ],
            "title": "Detail",
            "description": "Human-readable message or structured validation errors."
          },
          "code": {
            "type": "string",
            "title": "Code",
            "description": "Stable machine-readable error code."
          },
          "request_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Request Id",
            "description": "Echo of X-Request-ID when the server generated or accepted one."
          }
        },
        "type": "object",
        "required": [
          "detail",
          "code"
        ],
        "title": "ErrorResponse",
        "description": "Standard JSON error envelope (Phase 13 §13.0)."
      },
      "GPUStatusResponse": {
        "properties": {
          "available": {
            "type": "boolean",
            "title": "Available"
          },
          "active": {
            "type": "boolean",
            "title": "Active"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "default": ""
          },
          "uuid": {
            "type": "string",
            "title": "Uuid",
            "default": ""
          },
          "utilization_gpu": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Utilization Gpu"
          },
          "memory_used_mb": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Memory Used Mb"
          },
          "memory_total_mb": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Memory Total Mb"
          },
          "temperature_c": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
